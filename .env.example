# ═══════════════════════════════════════════════════════════════
# College Placement Portal — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
PORT=8080
VERTICLE_INSTANCES=1
PORTAL_URL=https://placement.example.com

# ── Database (MySQL) ─────────────────────────────────────────
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=placement
MYSQLUSER=root
MYSQLPASSWORD=

# ── AWS S3 (File Storage) ───────────────────────────────────
# Free tier: 5GB storage, 20K GET, 2K PUT/month for 12 months
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=placement-portal
S3_REGION=ap-south-1
# S3_ENDPOINT=              # Only for MinIO/R2/Spaces

# ── AI Service (Gemini) ─────────────────────────────────────
# Gemini 2.0 Flash is free for up to 15 RPM / 1M TPD
AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL=gemini-2.0-flash

# ── Email (SMTP) ────────────────────────────────────────────
# Gmail: smtp.gmail.com:587 with App Password
# AWS SES: email-smtp.ap-south-1.amazonaws.com:587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@placement.edu
SMTP_FROM_NAME=Placement Portal

# ── RabbitMQ (Message Queue) ────────────────────────────────
# CloudAMQP free: 1M messages/month, 20 connections
# RABBITMQ_URL=amqp://user:pass@host:port/vhost
RABBITMQ_URL=

# ── WhatsApp (Optional) ─────────────────────────────────────
# Meta Business API or Twilio
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
